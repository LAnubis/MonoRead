<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.BookSourceManagementPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,15" BackgroundColor="#FFFFFF">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="← 返回" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
            </Grid>

            <Label Grid.Column="1" Text="网络解析引擎" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center"/>

            <Grid Grid.Column="2" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShowImportOptionsCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="➕" FontSize="16" TextColor="#333333" VerticalOptions="Center" HorizontalOptions="Center"/>
            </Grid>
        </Grid>

        <RefreshView Grid.Row="1" Command="{Binding LoadSourcesCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Sources}" Margin="20">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView Margin="0,0,0,15">
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="删除" 
                                               BackgroundColor="#E57373"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:BookSourceManagementViewModel}}, Path=DeleteSourceCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="15">
                                <Grid ColumnDefinitions="Auto, *, Auto">

                                    <Switch Grid.Column="0" 
                                            IsToggled="{Binding IsEnabled}" 
                                            OnColor="#D1A67B" 
                                            VerticalOptions="Center" 
                                            Margin="0,0,15,0" />

                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                        <Label Text="{Binding Name}" FontSize="16" TextColor="#333333" FontAttributes="Bold" />
                                        <Label Text="{Binding BaseUrl}" FontSize="12" TextColor="#999999" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" Text="〉" FontSize="14" TextColor="#CCCCCC" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Margin="0,100,0,0">
                        <Label Text="暂无网络书源" HorizontalOptions="Center" TextColor="#999999" FontSize="16" />
                        <Label Text="点击右上角 ➕ 导入解析规则" FontSize="14" TextColor="#CCCCCC" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>