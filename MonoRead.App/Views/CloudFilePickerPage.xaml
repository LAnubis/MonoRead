<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.CloudFilePickerPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,15" BackgroundColor="#F5F5F5">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="关闭" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
            </Grid>
            <Label Grid.Column="1" Text="选择坚果云文件" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center"/>
            <ContentView Grid.Column="2" WidthRequest="50"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1">
            <Grid Padding="15,10" BackgroundColor="#FAFAFA" IsVisible="{Binding IsNotRoot}">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoUpDirectoryCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="↑ 返回上一级目录" FontSize="14" TextColor="#D1A67B" FontAttributes="Bold"/>
            </Grid>
            <BoxView HeightRequest="1" Color="#EEEEEE"/>

            <Grid>
                <CollectionView ItemsSource="{Binding Files}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="20,15" ColumnDefinitions="Auto, *, Auto">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.OpenNodeCommand}" CommandParameter="{Binding .}"/>
                                </Grid.GestureRecognizers>

                                <Label Grid.Column="0" Text="📄" FontSize="24" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsDirectory}" Value="True">
                                            <Setter Property="Text" Value="📁" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}" FontSize="16" TextColor="#333333" LineBreakMode="TailTruncation"/>

                                    <Label Text="{Binding ContentLength}" FontSize="12" TextColor="#999999" IsVisible="False">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsDirectory}" Value="False">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>

                                <CheckBox Grid.Column="2" 
                                          VerticalOptions="Center" 
                                          IsChecked="{Binding IsSelected}" 
                                          Color="#D1A67B"
                                          InputTransparent="True"
                                          IsVisible="False">
                                    <CheckBox.Triggers>
                                        <DataTrigger TargetType="CheckBox" Binding="{Binding IsDirectory}" Value="False">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </CheckBox.Triggers>
                                </CheckBox>

                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid BackgroundColor="#80FFFFFF" IsVisible="{Binding IsBusy}">
                    <ActivityIndicator IsRunning="True" Color="#D1A67B" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Grid>
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="2" BackgroundColor="#F5F5F5" Padding="20,15" IsVisible="{Binding HasSelectedFiles}">
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0" Text="{Binding SelectionStatusText}" TextColor="#333333" VerticalOptions="Center" FontAttributes="Bold" />

                <Button Grid.Column="1" Text="📥 导入选中书籍" Command="{Binding ConfirmImportCommand}" BackgroundColor="#D1A67B" TextColor="White" CornerRadius="8" Padding="15,10" />
            </Grid>
        </Grid>

    </Grid>
</ContentPage>