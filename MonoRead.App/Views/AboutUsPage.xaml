<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.AboutUsPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="Auto, *">

        <!-- 顶部导航栏 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,15" BackgroundColor="#FFFFFF">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=CurrentItem.Navigation.PopAsync}" />
                </Grid.GestureRecognizers>
                <Label Text="← 返回" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
            </Grid>
            <Label Grid.Column="1" Text="关于我们" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center"/>
            <ContentView Grid.Column="2" WidthRequest="50"/>
        </Grid>

        <!-- 核心内容区：大面积留白，垂直居中排布 -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
            <!-- 产品信息 -->
            <Label Text="MonoRead" FontSize="26" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" />
            <Label Text="V1.6" FontSize="14" TextColor="#999999" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <!-- 扩展字段 -->
            <Label Text="出品机构: MonoCraft Studio" FontSize="15" TextColor="#666666" HorizontalOptions="Center" />
            <Label Text="研发作者: Dr.Shawn" FontSize="15" TextColor="#666666" HorizontalOptions="Center" />

            <!-- 版权声明 (置于偏底部) -->
            <Label Text="Copyright © 2026" FontSize="12" TextColor="#B2B2B2" HorizontalOptions="Center" Margin="0,50,0,0"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>