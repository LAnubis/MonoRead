<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.ReaderPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{Binding PageBackgroundColor}">

    <Grid>

        <!-- ==================== 图层 1：底层 (翻页引擎核心区) ==================== -->
        <Grid RowDefinitions="*, Auto">

            <!-- CarouselView 横滑翻页容器 -->
            <!-- 【核心修复 4】：增加 AnimatePositionChanges="False" 彻底消除追加数据时的闪烁与乱跳 -->
            <!-- CarouselView 横滑翻页容器 -->
            <!-- 【修正】：已移除不存在的 AnimatePositionChanges 属性 -->
            <!-- 现在的防跳页完全由 ViewModel 中的 _isAppendingPages 锁来保障，更符合 MVVM 原则 -->
            <CarouselView x:Name="ReaderCarousel" 
                          Grid.Row="0"
                          ItemsSource="{Binding BookPages}" 
                          Position="{Binding CurrentPagePosition}"
                          Loop="False"
                          HorizontalScrollBarVisibility="Never">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,40,20,0">
                            <Label Text="{Binding Content}" 
                                   FontSize="{Binding BindingContext.ReaderFontSize, Source={x:Reference RootPage}}" 
                                   LineHeight="1.8" 
                                   TextColor="{Binding BindingContext.TextPrimaryColor, Source={x:Reference RootPage}}" 
                                   VerticalOptions="FillAndExpand" 
                                   HorizontalOptions="FillAndExpand"/>
                            <Label Text="{Binding PageIndex, StringFormat='{0}'}" 
                                   FontSize="10" 
                                   TextColor="{Binding BindingContext.StatusTextColor, Source={x:Reference RootPage}}" 
                                   HorizontalOptions="End" 
                                   VerticalOptions="End" 
                                   Margin="0,0,0,10"/>
                        </Grid>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <!-- 【手势捕捉区】：使用 Grid 彻底替代透明 BoxView 防黑屏，精准居中拦截 -->
            <Grid Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="100" HeightRequest="200" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleMenuCommand}" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- 底部常驻信息栏 -->
            <Grid Grid.Row="1" Margin="20,5,20,15">
                <Label Text="{Binding ChapterTitle}" FontSize="11" TextColor="{Binding StatusTextColor}" HorizontalOptions="Center" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
            </Grid>
        </Grid>

        <!-- ==================== 图层 2：悬浮控制面板层 ==================== -->
        <Grid RowDefinitions="Auto, *, Auto" IsVisible="{Binding IsMenuVisible}" BackgroundColor="Transparent">

            <!-- 【防黑屏净化】：退出菜单的外部透明区域替换为 Grid -->
            <Grid Grid.Row="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleMenuCommand}" />
                </Grid.GestureRecognizers>
            </Grid>

            <!-- 顶部栏 -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" BackgroundColor="#E61C1C1E" Padding="15,40,15,15">
                <Button Grid.Column="0" Text="← 返回" Command="{Binding GoBackCommand}" BackgroundColor="Transparent" TextColor="White" />
                <Label Grid.Column="1" Text="设置" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- 底部设置面板 -->
            <Border Grid.Row="2" BackgroundColor="#E61C1C1E" Padding="20" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0">
                <VerticalStackLayout Spacing="25">

                    <Grid ColumnDefinitions="Auto, *">
                        <Button Grid.Column="0" Text="三 目录" Command="{Binding ToggleTocCommand}" BackgroundColor="Transparent" TextColor="White" FontSize="16" />

                        <!-- 保留手动切换上一章/下一章入口 -->
                        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="10">
                            <Button Text="上一章" Command="{Binding PreviousChapterCommand}" IsEnabled="{Binding CanGoPrevious}" BackgroundColor="Transparent" TextColor="#888" FontSize="12" Padding="5"/>
                            <Button Text="下一章" Command="{Binding NextChapterCommand}" IsEnabled="{Binding CanGoNext}" BackgroundColor="Transparent" TextColor="#888" FontSize="12" Padding="5"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#33FFFFFF" />

                    <!-- 主题切换 -->
                    <Grid ColumnDefinitions="*, *, *">
                        <Button Grid.Column="0" Text="日间" Command="{Binding ChangeThemeCommand}" CommandParameter="Day" BackgroundColor="#FFFFFF" TextColor="#333333" CornerRadius="20" Margin="5,0"/>
                        <Button Grid.Column="1" Text="护眼" Command="{Binding ChangeThemeCommand}" CommandParameter="EyeCare" BackgroundColor="#F4ECD8" TextColor="#3E3222" CornerRadius="20" Margin="5,0"/>
                        <Button Grid.Column="2" Text="夜间" Command="{Binding ChangeThemeCommand}" CommandParameter="Night" BackgroundColor="#1A1A1C" TextColor="#999999" CornerRadius="20" Margin="5,0"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#33FFFFFF" />

                    <!-- 字体排版控制 -->
                    <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                        <Label Grid.Column="0" Text="A-" FontSize="16" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="缩小" Command="{Binding DecreaseFontCommand}" BackgroundColor="#33FFFFFF" TextColor="White" HeightRequest="40" CornerRadius="20" Margin="10,0"/>
                        <Label Grid.Column="2" Text="{Binding ReaderFontSize}" TextColor="#888888" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Button Grid.Column="3" Text="放大" Command="{Binding IncreaseFontCommand}" BackgroundColor="#33FFFFFF" TextColor="White" HeightRequest="40" CornerRadius="20" Margin="10,0"/>
                        <Label Grid.Column="4" Text="A+" FontSize="20" TextColor="White" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#33FFFFFF" />

                    <!-- 独立文字颜色调色板 -->
                    <Grid ColumnDefinitions="Auto, *, *, *, *, *">
                        <Label Grid.Column="0" Text="文字颜色" FontSize="14" TextColor="#888888" VerticalOptions="Center" Margin="0,0,15,0" />
                        <Border Grid.Column="1" BackgroundColor="#222222" Stroke="#555555" StrokeThickness="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeTextColorCommand}" CommandParameter="#222222" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#4E342E" Stroke="#555555" StrokeThickness="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeTextColorCommand}" CommandParameter="#4E342E" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="3" BackgroundColor="#757575" Stroke="#555555" StrokeThickness="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeTextColorCommand}" CommandParameter="#757575" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="4" BackgroundColor="#BDBDBD" Stroke="#555555" StrokeThickness="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeTextColorCommand}" CommandParameter="#BDBDBD" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="5" BackgroundColor="#FFFFFF" Stroke="#555555" StrokeThickness="1" WidthRequest="36" HeightRequest="36" StrokeShape="RoundRectangle 18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeTextColorCommand}" CommandParameter="#FFFFFF" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ==================== 图层 3：全屏目录面板 ==================== -->
        <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsTocVisible}" BackgroundColor="{Binding PageBackgroundColor}">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,40,20,15" BackgroundColor="Transparent">
                <Label Grid.Column="0" Text="目录" FontSize="20" FontAttributes="Bold" TextColor="{Binding TextPrimaryColor}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="关闭" Command="{Binding ToggleTocCommand}" BackgroundColor="Transparent" TextColor="{Binding StatusTextColor}" />
            </Grid>

            <BoxView Grid.Row="0" HeightRequest="1" Color="#22000000" VerticalOptions="End" />

            <CollectionView Grid.Row="1" ItemsSource="{Binding ChaptersList}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ReaderViewModel}}, Path=SelectChapterCommand}" CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <Label Text="{Binding Title}" FontSize="16" TextColor="{Binding BindingContext.TextPrimaryColor, Source={x:Reference RootPage}}" LineBreakMode="TailTruncation" MaxLines="1" />
                            <BoxView HeightRequest="1" Color="#11000000" VerticalOptions="End" Margin="0,15,-20,-15" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- 全屏加载遮罩 -->
        <Grid BackgroundColor="#CC000000" IsVisible="{Binding IsLoading}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsLoading}" Color="White" WidthRequest="50" HeightRequest="50" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>