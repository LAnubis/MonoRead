<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.ReaderPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{Binding PageBackgroundColor}">

    <Grid>
        <!-- ==================== 图层 1：底层瀑布流阅读区 ==================== -->
        <Grid RowDefinitions="*, Auto">

            <CollectionView Grid.Row="0"
                            ItemsSource="{Binding ReadingStream}"
                            RemainingItemsThreshold="0"
                            RemainingItemsThresholdReachedCommand="{Binding LoadNextChapterSeamlesslyCommand}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <!-- 兜底：处理页面边缘、空白区域的点击，用于呼出/隐藏阅读菜单 -->
                        <VerticalStackLayout Padding="20,40,20,40">
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.ProcessTapCommand, Source={x:Reference RootPage}}" />
                            </VerticalStackLayout.GestureRecognizers>

                            <Label Text="{Binding Title}" FontSize="28" FontAttributes="Bold" TextColor="{Binding BindingContext.TextPrimaryColor, Source={x:Reference RootPage}}" Margin="0,0,0,30" />

                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Paragraphs}" Spacing="15">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <!-- 【极简核心】：彻底剥离 MAUI 手势。仅保留 StyleClass="ReadingText"，由 MauiProgram 注入 Android 原生能力 -->
                                        <Label Text="{Binding .}" 
                                               StyleClass="ReadingText"
                                               FontSize="{Binding BindingContext.ReaderFontSize, Source={x:Reference RootPage}}" 
                                               LineHeight="1.8" 
                                               TextColor="{Binding BindingContext.TextPrimaryColor, Source={x:Reference RootPage}}" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#1A000000" Margin="0,40,0,0" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- 触底兜底加载区域 -->
                <CollectionView.Footer>
                    <Grid Padding="20" BackgroundColor="Transparent">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoadNextChapterSeamlesslyCommand}" />
                        </Grid.GestureRecognizers>
                        <ActivityIndicator IsRunning="{Binding IsLoadingNext}" Color="{Binding StatusTextColor}" HorizontalOptions="Center" IsVisible="{Binding IsLoadingNext}" />
                        <Label Text="点击加载下一章" TextColor="{Binding StatusTextColor}" HorizontalOptions="Center" FontSize="12">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsLoadingNext}" Value="True">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding CanGoNext}" Value="False">
                                    <Setter Property="Text" Value="已经是最后一章了" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>
                </CollectionView.Footer>
            </CollectionView>

            <Grid Grid.Row="1" Margin="20,5,20,15">
                <Label Text="{Binding ChapterTitle}" FontSize="11" TextColor="{Binding StatusTextColor}" HorizontalOptions="Center" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1"/>
            </Grid>
        </Grid>

        <!-- ==================== 图层 2：悬浮设置菜单栏 ==================== -->
        <Grid RowDefinitions="Auto, *, Auto" IsVisible="{Binding IsMenuVisible}" BackgroundColor="Transparent">
            <!-- 退出菜单的透明遮罩 -->
            <Grid Grid.Row="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ProcessTapCommand}" />
                </Grid.GestureRecognizers>
            </Grid>

            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" BackgroundColor="#E61C1C1E" Padding="15,40,15,15">
                <Button Grid.Column="0" Text="← 返回" Command="{Binding GoBackCommand}" BackgroundColor="Transparent" TextColor="White" />
                <Label Grid.Column="1" Text="设置" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <Border Grid.Row="2" BackgroundColor="#E61C1C1E" Padding="20" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0">
                <VerticalStackLayout Spacing="25">
                    <Grid ColumnDefinitions="Auto, *">
                        <Button Grid.Column="0" Text="三 目录" Command="{Binding ToggleTocCommand}" BackgroundColor="Transparent" TextColor="White" FontSize="16" />
                        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="10" VerticalOptions="Center">
                            <Button Text="上一章" Command="{Binding PreviousChapterCommand}" IsEnabled="{Binding CanGoPrevious}" BackgroundColor="Transparent" TextColor="#AAAAAA" FontSize="12" Padding="5"/>
                            <Button Text="下一章" Command="{Binding NextChapterCommand}" IsEnabled="{Binding CanGoNext}" BackgroundColor="Transparent" TextColor="#AAAAAA" FontSize="12" Padding="5"/>
                        </HorizontalStackLayout>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#33FFFFFF" />
                    <!-- 主题切换 -->
                    <Grid ColumnDefinitions="*, *, *">
                        <Button Grid.Column="0" Text="日间" Command="{Binding ChangeThemeCommand}" CommandParameter="Day" BackgroundColor="#FFFFFF" TextColor="#333333" CornerRadius="20" Margin="5,0"/>
                        <Button Grid.Column="1" Text="护眼" Command="{Binding ChangeThemeCommand}" CommandParameter="EyeCare" BackgroundColor="#F4ECD8" TextColor="#3E3222" CornerRadius="20" Margin="5,0"/>
                        <Button Grid.Column="2" Text="夜间" Command="{Binding ChangeThemeCommand}" CommandParameter="Night" BackgroundColor="#1A1A1C" TextColor="#999999" CornerRadius="20" Margin="5,0"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#33FFFFFF" />
                    <!-- 字号设置 -->
                    <Grid ColumnDefinitions="Auto, *, Auto, *, Auto">
                        <Label Grid.Column="0" Text="A-" FontSize="16" TextColor="White" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="缩小" Command="{Binding DecreaseFontCommand}" BackgroundColor="#33FFFFFF" TextColor="White" HeightRequest="40" CornerRadius="20" Margin="10,0"/>
                        <Label Grid.Column="2" Text="{Binding ReaderFontSize}" TextColor="#888888" VerticalOptions="Center" HorizontalOptions="Center"/>
                        <Button Grid.Column="3" Text="放大" Command="{Binding IncreaseFontCommand}" BackgroundColor="#33FFFFFF" TextColor="White" HeightRequest="40" CornerRadius="20" Margin="10,0"/>
                        <Label Grid.Column="4" Text="A+" FontSize="20" TextColor="White" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ==================== 图层 4：原生联动摘录工作台 ==================== -->
        <Grid RowDefinitions="Auto, *, Auto, Auto" IsVisible="{Binding IsNoteOverlayVisible}" BackgroundColor="#FDFDFD">

            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,15" BackgroundColor="#FFFFFF">
                <Button Grid.Column="0" Text="取消" Command="{Binding CloseNoteWorkbenchCommand}" BackgroundColor="Transparent" TextColor="#666666" />
                <Label Grid.Column="1" Text="写笔记" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="保存" Command="{Binding SaveNoteCommand}" BackgroundColor="Transparent" TextColor="#D1A67B" FontAttributes="Bold" />
            </Grid>
            <BoxView Grid.Row="0" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End" />

            <Grid Grid.Row="1" Padding="20">
                <Label Text="你已选中以下金句：" FontSize="12" TextColor="#999999" VerticalOptions="Start" />

                <!-- 原生选词完毕后的纯净展示 -->
                <Label Text="{Binding ExtractTargetParagraph}" 
                       FontSize="18" 
                       TextColor="#666666" 
                       LineHeight="1.5"
                       Margin="0,25,0,0" 
                       VerticalOptions="Start" />
            </Grid>

            <Border Grid.Row="2" BackgroundColor="#FFFFFF" Stroke="#DDDDDD" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="15" Margin="20,0,20,30" HeightRequest="150">
                <Editor Text="{Binding UserNoteInput}" 
                        Placeholder="记录你的感悟..." 
                        PlaceholderColor="#CCCCCC" 
                        FontSize="16" 
                        TextColor="#333333" 
                        VerticalOptions="FillAndExpand" />
            </Border>
        </Grid>

        <!-- 加载遮罩 -->
        <Grid BackgroundColor="#CC000000" IsVisible="{Binding IsLoading}">
            <ActivityIndicator IsRunning="{Binding IsLoading}" Color="White" WidthRequest="50" HeightRequest="50" HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>