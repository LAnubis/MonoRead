<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.BookNotesDetailPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ==================== 顶部导航栏 ==================== -->
        <!-- 修改了 ColumnDefinitions，追加了一列给导出按钮 -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Padding="15,40,15,15" BackgroundColor="#FFFFFF">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="← 返回" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
            </Grid>

            <Label Grid.Column="1" Text="{Binding BookTitle}" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

            <!-- 【新增导出按钮】 -->
            <Button Grid.Column="2" Text="📤 导出" Command="{Binding ExportToMarkdownCommand}" BackgroundColor="Transparent" TextColor="#666666" FontAttributes="Bold" Margin="0,0,5,0" />

            <Button Grid.Column="3" Text="{Binding ManageButtonText}" Command="{Binding ToggleManageModeCommand}" BackgroundColor="Transparent" TextColor="#D1A67B" FontAttributes="Bold" />
        </Grid>
        <BoxView Grid.Row="0" HeightRequest="1" Color="#EEEEEE" VerticalOptions="End" />

        <!-- ==================== 笔记瀑布流 (分组+折叠引擎) ==================== -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding GroupedNotes}" IsGrouped="True" SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" Margin="0,100,0,0">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#D1A67B" />
                    <Label Text="本页面暂无笔记记录" FontSize="16" TextColor="#999999" IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <!-- 章节大纲标题 (Group Header) -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid Padding="20,25,20,10" BackgroundColor="#FFFFFF">
                        <Label Text="{Binding ChapterTitle}" FontSize="14" FontAttributes="Bold" TextColor="#D1A67B" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- 笔记实体条目 (Item) -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <!-- 外层容器：管理模式下点击可勾选 -->
                    <Grid Padding="20,10,20,15" ColumnDefinitions="Auto, *">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSelectionCommand}" />
                        </Grid.GestureRecognizers>

                        <!-- 管理模式复选框 -->
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalOptions="Center" Margin="0,0,15,0" Color="#D1A67B">
                            <CheckBox.IsVisible>
                                <Binding Path="BindingContext.IsManageMode" Source="{x:Reference RootPage}" />
                            </CheckBox.IsVisible>
                        </CheckBox>

                        <!-- 主体内容 -->
                        <VerticalStackLayout Grid.Column="1">

                            <!-- 第一行：引用的原书划线 (非管理模式下点击触发折叠/展开) -->
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleExpandCommand}"/>
                                </Grid.GestureRecognizers>

                                <!-- 左侧极简灰色引用线 -->
                                <BoxView Grid.Column="0" WidthRequest="3" Color="#E0E0E0" CornerRadius="1.5" />

                                <!-- 原文引用 -->
                                <Label Grid.Column="1" Text="{Binding Note.SelectedText}" FontSize="15" TextColor="#888888" LineHeight="1.5" LineBreakMode="WordWrap" VerticalOptions="Center"/>

                                <!-- 📝 提示图标 (仅当有个人想法，且处于折叠状态时才显示，展开后自动隐藏) -->
                                <Label Grid.Column="2" Text="📝" FontSize="12" VerticalOptions="Start" Margin="5,2,0,0">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding HasComment}" Value="False">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>

                            <!-- 第二行：用户个人想法 (展开状态下丝滑显示) -->
                            <VerticalStackLayout Margin="13,12,0,0" IsVisible="{Binding IsExpanded}">
                                <Label Text="{Binding Note.UserComment}" FontSize="15" TextColor="#333333" LineHeight="1.6" LineBreakMode="WordWrap"/>
                                <Label Text="{Binding Note.CreatedAt, StringFormat='{0:yyyy-MM-dd HH:mm}'}" FontSize="11" TextColor="#CCCCCC" Margin="0,8,0,0" HorizontalOptions="End"/>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ==================== 底部删除操作台 ==================== -->
        <Grid Grid.Row="2" BackgroundColor="#FFFFFF" Padding="20,15,20,35" 
              IsVisible="{Binding IsManageMode}">
            <BoxView HeightRequest="1" Color="#EEEEEE" VerticalOptions="Start" Margin="-20,-15,-20,0" />

            <Button Text="删除选中笔记" 
                    Command="{Binding DeleteSelectedNotesCommand}" 
                    BackgroundColor="#E57373" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="25" 
                    HeightRequest="50"/>
        </Grid>
    </Grid>
</ContentPage>