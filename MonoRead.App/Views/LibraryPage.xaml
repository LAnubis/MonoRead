<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.LibraryPage"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20,15,20,10">
            <Label Grid.Column="0" 
                   Text="书架" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" />

            <Button Grid.Column="2" 
                    Text="+ 导入书籍" 
                    Style="{StaticResource PrimaryButton}" 
                    Command="{Binding ImportBookCommand}"
                    Padding="16,8" 
                    CornerRadius="20" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" 
                             VerticalOptions="Center" 
                             HorizontalOptions="Center" 
                             Spacing="16">

            <Label Text="📚" 
                   FontSize="72" 
                   HorizontalOptions="Center" 
                   Opacity="0.8"/>

            <Label Text="你的书架空空如也" 
                   FontSize="16" 
                   TextColor="{StaticResource TextSecondary}" 
                   HorizontalOptions="Center" />

            <Label Text="点击右上角导入第一本本地小说吧" 
                   FontSize="14" 
                   TextColor="{StaticResource TextPlaceholder}" 
                   HorizontalOptions="Center" />

        </VerticalStackLayout>

    </Grid>
</ContentPage>