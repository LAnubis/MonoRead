<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodels="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.LibraryPage"
             Shell.NavBarIsVisible="False"
             x:Name="RootPage">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="Auto, *, Auto">

            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Padding="20,15,20,10">
                <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="10">
                    <Button Text="⬅" 
                            IsVisible="{Binding IsNotRoot}" 
                            Command="{Binding GoBackCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{StaticResource TextPrimary}" 
                            FontSize="24" 
                            Padding="0" 
                            Margin="0" 
                            VerticalOptions="Center"/>
                    <Label Text="{Binding CurrentPathName}" 
                           FontSize="28" 
                           FontAttributes="Bold" 
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Button Grid.Column="1" 
                        Text="{Binding EditModeButtonText}" 
                        Command="{Binding ToggleEditModeCommand}" 
                        BackgroundColor="Transparent" 
                        TextColor="{StaticResource TextSecondary}" 
                        FontSize="14" 
                        Padding="10,8" 
                        Margin="0,0,10,0"/>

                <Button Grid.Column="2" 
                        Text="+ 导入书籍" 
                        IsVisible="{Binding IsNotRoot, Converter={StaticResource InvertedBoolConverter}}"
                        Style="{StaticResource PrimaryButton}" 
                        Command="{Binding ImportBookCommand}" 
                        Padding="16,8" 
                        CornerRadius="20" />
            </Grid>

            <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
                        <Label Text="📦" FontSize="72" HorizontalOptions="Center" Opacity="0.8"/>
                        <Label Text="这里空空如也" FontSize="16" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,10" ColumnDefinitions="60, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding BindingContext.OpenItemCommand, Source={x:Reference RootPage}}" 
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <Border Grid.Column="0" IsVisible="{Binding IsFolder}" HeightRequest="80" WidthRequest="60" BackgroundColor="#FFF8E1" Stroke="#FFE082" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                                <Label Text="📁" VerticalOptions="Center" HorizontalOptions="Center" FontSize="32"/>
                            </Border>

                            <Border Grid.Column="0" IsVisible="{Binding IsFolder, Converter={StaticResource InvertedBoolConverter}}" HeightRequest="80" WidthRequest="60" BackgroundColor="{StaticResource BgLight}" Stroke="{StaticResource TextPlaceholder}" StrokeThickness="1" StrokeShape="RoundRectangle 4">
                                <Label Text="TXT" VerticalOptions="Center" HorizontalOptions="Center" TextColor="{StaticResource TextSecondary}" FontSize="12"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0">
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <Label Text="{Binding Subtitle}" FontSize="12" TextColor="{StaticResource TextSecondary}" Margin="0,5,0,0" />
                            </VerticalStackLayout>

                            <CheckBox Grid.Column="2" 
                                      VerticalOptions="Center" 
                                      IsChecked="{Binding IsSelected}" 
                                      InputTransparent="True" 
                                      IsVisible="{Binding ShowCheckBox}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="2" Padding="20,15" BackgroundColor="#F5F5F5" IsVisible="{Binding IsEditMode}" ColumnDefinitions="*, *">
                <Button Grid.Column="0" 
                        Text="📁 移动" 
                        Command="{Binding MoveSelectedItemsToFolderCommand}" 
                        Style="{StaticResource PrimaryButton}" 
                        CornerRadius="8" 
                        Margin="0,0,10,0"/>

                <Button Grid.Column="1" 
                        Text="🗑️ 删除" 
                        Command="{Binding DeleteSelectedItemsCommand}" 
                        BackgroundColor="#FFEbee" 
                        TextColor="#E57373" 
                        FontAttributes="Bold"
                        CornerRadius="8" 
                        Margin="10,0,0,0"/>
            </Grid>

        </Grid>

        <Grid BackgroundColor="#CC000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" WidthRequest="50" HeightRequest="50" />
                <Label Text="{Binding BusyMessage}" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>