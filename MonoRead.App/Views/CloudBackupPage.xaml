<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.CloudBackupPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,15" BackgroundColor="#FFFFFF">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="← 返回" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
            </Grid>
            <Label Grid.Column="1" Text="云端配置" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center"/>
            <ContentView Grid.Column="2" WidthRequest="50" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="15">

                <Border BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="20">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="连接坚果云 (WebDAV)" FontSize="16" FontAttributes="Bold" TextColor="#333333"/>
                        <Label Text="请不要使用您的登录密码。必须前往坚果云官网生成【应用授权密码】进行绑定，保障您的主账号安全。" FontSize="12" TextColor="#999999" />

                        <VerticalStackLayout Spacing="5">
                            <Label Text="服务器地址 (WebDAV URL)" FontSize="12" TextColor="#666666"/>
                            <Entry Text="{Binding ServerUrl}" Placeholder="https://dav.jianguoyun.com/dav/" TextColor="#333333"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="坚果云账号 (通常为邮箱)" FontSize="12" TextColor="#666666"/>
                            <Entry Text="{Binding Username}" Placeholder="example@email.com" Keyboard="Email" TextColor="#333333"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="应用授权密码" FontSize="12" TextColor="#666666"/>
                            <Entry Text="{Binding Password}" IsPassword="True" Placeholder="非网页登录密码" TextColor="#333333"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- 测试按钮与状态 -->
                <!--<Button Text="测试连接并保存" Command="{Binding SaveAndTestAsync}" BackgroundColor="#D1A67B" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" />-->
                <!-- 【核心修复】：将 Async 后缀改为 Command 后缀 -->
                <Button Text="测试连接并保存" Command="{Binding SaveAndTestCommand}" BackgroundColor="#D1A67B" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" />
                <Label Text="{Binding TestResultText}" TextColor="{Binding TestResultColor}" HorizontalOptions="Center" FontSize="14" Margin="0,10,0,0"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#D1A67B" HorizontalOptions="Center" Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>