<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="设置"
             BackgroundColor="#F7F7F7">
    <!-- 更柔和的全局浅灰底色 -->

    <Grid RowDefinitions="Auto, *">

        <!-- 顶部大标题区域 -->
        <Grid Grid.Row="0" Padding="20,50,20,15" BackgroundColor="#F7F7F7">
            <Label Text="设置" FontSize="30" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center" />
        </Grid>

        <!-- 设置项列表区 -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

                <!-- ==================== 阅读统计卡片 ==================== -->
                <!-- 利用阴影和圆角打造微凸起的高级卡片感 -->
                <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 16" StrokeThickness="0" Margin="20,10,20,30" Padding="25">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,6" Radius="15" Opacity="0.04" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">
                        <Grid ColumnDefinitions="*, *">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="累计阅读" FontSize="13" TextColor="#999999" />
                                <HorizontalStackLayout VerticalOptions="End">
                                    <Label Text="{Binding TotalReadMinutes}" FontSize="32" FontFamily="Arial" FontAttributes="Bold" TextColor="#333333" />
                                    <Label Text=" 分钟" FontSize="12" TextColor="#999999" VerticalOptions="End" Margin="2,0,0,6" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="连续打卡" FontSize="13" TextColor="#999999" />
                                <HorizontalStackLayout VerticalOptions="End">
                                    <Label Text="{Binding ContinuousReadDays}" FontSize="32" FontFamily="Arial" FontAttributes="Bold" TextColor="#D1A67B" />
                                    <Label Text=" 天" FontSize="12" TextColor="#999999" VerticalOptions="End" Margin="2,0,0,6" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F5F5F5" />

                        <!-- GitHub 绿点热力图占位区 -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="过去 90 天阅读分布" FontSize="12" TextColor="#AAAAAA" />
                            <FlexLayout BindableLayout.ItemsSource="{Binding HeatBoxes}" Wrap="Wrap" Direction="Row" JustifyContent="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <BoxView WidthRequest="12" HeightRequest="12" Color="{Binding ColorHex}" CornerRadius="2" Margin="2" />
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ==================== 模块 1：阅读体验 ==================== -->
                <Label Text="阅读体验" FontSize="13" TextColor="#999999" Margin="20,0,0,8" />
                <VerticalStackLayout BackgroundColor="#FFFFFF" Margin="0,0,0,25">
                    <Grid Padding="20,15" ColumnDefinitions="Auto, *, Auto">
                        <Label Grid.Column="0" Text="📜" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="启用瀑布流模式" FontSize="16" TextColor="#333333" />
                            <Label Text="关闭时为沉浸式左右翻页" FontSize="12" TextColor="#999999" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="2" IsToggled="{Binding IsScrollMode}" OnColor="#D1A67B" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ==================== 模块 2：数据与系统 ==================== -->
                <Label Text="数据与系统" FontSize="13" TextColor="#999999" Margin="20,0,0,8" />
                <VerticalStackLayout BackgroundColor="#FFFFFF" Margin="0,0,0,25">

                    <Grid Padding="20,18" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTrashCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="🗑️" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="回收站" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="〉" FontSize="14" TextColor="#CCCCCC" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F7F7F7" Margin="55,0,0,0" />

                    <Grid Padding="20,18" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCloudBackupCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="☁️" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="云端备份 (WebDAV)" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="〉" FontSize="14" TextColor="#CCCCCC" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#F7F7F7" Margin="55,0,0,0" />

                    <Grid Padding="20,18" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportLogCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="📝" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="导出日志" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="〉" FontSize="14" TextColor="#CCCCCC" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ==================== 模块 3：关于 ==================== -->
                <VerticalStackLayout BackgroundColor="#FFFFFF">
                    <Grid Padding="20,18" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToAboutUsCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="✨" FontSize="20" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="关于我们" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="〉" FontSize="14" TextColor="#CCCCCC" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>