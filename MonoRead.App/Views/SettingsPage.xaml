<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="设置"
             BackgroundColor="#F5F5F5">
    <!-- 微信读书设置页底色通常为浅灰 -->

    <Grid RowDefinitions="Auto, *">

        <!-- 顶部大标题区域 -->
        <Grid Grid.Row="0" Padding="20,40,20,20" BackgroundColor="#F5F5F5">
            <Label Text="设置" FontSize="28" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center" />
        </Grid>

        <!-- 设置项列表区 -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="0">

                <!-- ==================== 新增：阅读统计与日历热力图卡片 ==================== -->
                <Border BackgroundColor="#FFFFFF" StrokeShape="RoundRectangle 12" StrokeThickness="0" Margin="20,0,20,20" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="15">

                        <!-- 顶部数据汇总 -->
                        <Grid ColumnDefinitions="*, *">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="累计阅读" FontSize="12" TextColor="#999999" />
                                <HorizontalStackLayout VerticalOptions="End">
                                    <Label Text="{Binding TotalReadMinutes}" FontSize="28" FontAttributes="Bold" TextColor="#333333" />
                                    <Label Text=" 分钟" FontSize="12" TextColor="#999999" VerticalOptions="End" Margin="0,0,0,5" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="连续打卡" FontSize="12" TextColor="#999999" />
                                <HorizontalStackLayout VerticalOptions="End">
                                    <Label Text="{Binding ContinuousReadDays}" FontSize="28" FontAttributes="Bold" TextColor="#D1A67B" />
                                    <Label Text=" 天" FontSize="12" TextColor="#999999" VerticalOptions="End" Margin="0,0,0,5" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,5"/>

                        <!-- GitHub 绿点热力图 -->
                        <Label Text="过去 90 天阅读分布" FontSize="12" TextColor="#AAAAAA" Margin="0,0,0,5"/>
                        <FlexLayout BindableLayout.ItemsSource="{Binding HeatBoxes}" 
                                    Wrap="Wrap" 
                                    Direction="Row" 
                                    JustifyContent="Start" 
                                    AlignItems="Start">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <!-- 每个代表一天的小方块 -->
                                    <BoxView WidthRequest="12" 
                                             HeightRequest="12" 
                                             Color="{Binding ColorHex}" 
                                             CornerRadius="2" 
                                             Margin="2" 
                                             ToolTipProperties.Text="{Binding Tooltip}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ==================== 新增：阅读偏好设置 ==================== -->
                <Label Text="阅读体验" FontSize="13" TextColor="#999999" Margin="25,0,0,10" />
                <VerticalStackLayout BackgroundColor="#FFFFFF" Margin="0,0,0,25">
                    <Grid Padding="20,12" ColumnDefinitions="Auto, *, Auto">
                        <Label Grid.Column="0" Text="📜" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="启用瀑布流模式" FontSize="16" TextColor="#333333" />
                            <Label Text="关闭时为左右翻页模式" FontSize="11" TextColor="#999999" Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                        <!-- 核心开关，绑定 ViewModel -->
                        <Switch Grid.Column="2" IsToggled="{Binding IsScrollMode}" OnColor="#D1A67B" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ==================== 模块组 1：数据管理 ==================== -->
                <Label Text="数据与系统" FontSize="13" TextColor="#999999" Margin="25,0,0,10" />
                <VerticalStackLayout BackgroundColor="#FFFFFF" Margin="0,0,0,15">

                    <!-- Item 1: 回收站 -->
                    <Grid Padding="20,16" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToTrashCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="🗑️" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="回收站" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#B2B2B2" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>

                    <!-- 分割线 -->
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="20,0,0,0" HorizontalOptions="FillAndExpand" />
                    <Grid Padding="20,16" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCloudBackupCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="☁️" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="云端备份 (坚果云)" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#B2B2B2" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>

                    <!-- 分割线 -->
                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="20,0,0,0" HorizontalOptions="FillAndExpand" />
                    <!-- Item 2: 导出崩溃日志 -->
                    <Grid Padding="20,16" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportLogCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="📝" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="导出日志" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#B2B2B2" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>

                <!-- ==================== 模块组 2：关于 ==================== -->
                <VerticalStackLayout BackgroundColor="#FFFFFF">

                    <!-- Item 3: 关于我们 -->
                    <Grid Padding="20,16" ColumnDefinitions="Auto, *, Auto">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToAboutUsCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0" Text="ℹ️" FontSize="18" VerticalOptions="Center" Margin="0,0,15,0"/>
                        <Label Grid.Column="1" Text="关于我们" FontSize="16" TextColor="#333333" VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="#B2B2B2" VerticalOptions="Center" FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>

                <!-- 底部版本号声明 -->
                <Label Text="MonoRead V1.6" 
                       FontSize="12" 
                       TextColor="#B2B2B2" 
                       HorizontalOptions="Center" 
                       Margin="0,40,0,40"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>