<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonoRead.App.Views.ReaderPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{StaticResource BgLight}">
    <Grid RowDefinitions="Auto, *, Auto" Padding="20,40,20,20">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,20">
            <Button Grid.Column="0" 
                    Text="←" 
                    Command="{Binding GoBackCommand}"
                    FontSize="18"
                    Padding="0"
                    WidthRequest="40"
                    TextColor="{StaticResource TextSecondary}" />

            <Label Grid.Column="1" 
                   Text="{Binding ChapterTitle}" 
                   FontSize="12" 
                   TextColor="{StaticResource TextSecondary}" 
                   VerticalOptions="Center" 
                   HorizontalOptions="End"/>
        </Grid>

        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <Label Text="{Binding PageContent}" 
                   FontSize="18" 
                   LineHeight="1.8"
                   TextColor="{StaticResource TextPrimary}" />
        </ScrollView>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,10,0,0">
            <Label Grid.Column="0" Text="0.1%" FontSize="10" TextColor="{StaticResource TextPlaceholder}" />
            <Label Grid.Column="1" Text="12:00" FontSize="10" TextColor="{StaticResource TextPlaceholder}" HorizontalOptions="End" />
        </Grid>

    </Grid>
</ContentPage>