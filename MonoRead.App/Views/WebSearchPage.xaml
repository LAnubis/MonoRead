<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MonoRead.App.ViewModels"
             x:Class="MonoRead.App.Views.WebSearchPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="15,40,15,10" BackgroundColor="#FFFFFF">
            <Label Grid.Column="0" Text="← 返回" FontSize="16" TextColor="#333333" VerticalOptions="Center" Padding="10">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="1" Text="全网搜书" FontSize="18" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center" VerticalOptions="Center"/>
            <ContentView Grid.Column="2" WidthRequest="50" />
        </Grid>

        <Border Grid.Row="1" BackgroundColor="#FFFFFF" StrokeThickness="0" Padding="15,10,15,20">
            <SearchBar Placeholder="输入你想看的小说名称..." 
                       Text="{Binding SearchKeyword}"
                       SearchCommand="{Binding PerformSearchCommand}"
                       CancelButtonColor="#D1A67B" />
        </Border>

        <Grid Grid.Row="2">
            <VerticalStackLayout IsVisible="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Spacing="15" ZIndex="2">
                <ActivityIndicator IsRunning="True" Color="#D1A67B" />
                <Label Text="{Binding BusyMessage}" TextColor="#999999" FontSize="14" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding SearchResults}" Margin="15" ZIndex="1">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#FFFFFF" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="15" Margin="0,0,0,15">
                            <Grid ColumnDefinitions="80, *, Auto" ColumnSpacing="15">

                                <Frame Grid.Column="0" CornerRadius="4" Padding="0" HasShadow="False" BackgroundColor="#EBEDF0" HeightRequest="105" WidthRequest="75" VerticalOptions="Start">
                                    <Image Source="{Binding CoverUrl}" Aspect="AspectFill" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" Spacing="6">
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="#333333" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Author, StringFormat='作者：{0}'}" FontSize="12" TextColor="#D1A67B" />
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#999999" MaxLines="3" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>

                                <Button Grid.Column="2" 
                                        Text="下载" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:WebSearchViewModel}}, Path=DownloadBookCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F0F8FF" 
                                        TextColor="#0066CC" 
                                        FontAttributes="Bold"
                                        CornerRadius="15" 
                                        HeightRequest="30" 
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>